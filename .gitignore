### Go ###
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.txt
coverage.html
*.coverprofile

# Dependency directories
vendor/

# Go workspace file
go.work
go.work.sum

### Microservice REST specific ###
# Build artifacts
bin/
dist/
build/
*.bin

# Environment files
.env
.env.local
.env.*.local
*.env

# Configuration files with secrets
*secret*.yaml
*secret*.yml
*secret*.json
config/local.yaml
config/local.yml

# Logs
*.log
logs/
*.log.*

# Database
*.db
*.sqlite
*.sqlite3

